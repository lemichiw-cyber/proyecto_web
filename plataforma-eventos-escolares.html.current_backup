      }

      function examComenzar() {
        var idx = parseInt($('exam-select').value, 10);
        if (isNaN(idx) || !examenes[idx]) { mostrarToast('Selecciona un examen válido.', 'error'); return; }
        examEnCurso = {
          idx: idx,
          examen: JSON.parse(JSON.stringify(examenes[idx])),
          respuestas: [],
          tiempoRestante: examenes[idx].tiempo * 60,
          iniciado: Date.now()
        };
        examRenderSimulador();
        examIniciarTimer();
      }

      function examRenderSimulador() {
        if (!examEnCurso) return;
        $('exam-selector').classList.add('hidden');
        $('exam-simulador').classList.remove('hidden');
        $('exam-resultado').classList.add('hidden');
        var ex = examEnCurso.examen;
        var t = examEnCurso.tiempoRestante;
        var m = Math.floor(t / 60);
        var s = t % 60;
        $('exam-timer').textContent = String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
        $('exam-timer').className = 'timer';
        $('exam-progress').textContent = '0/' + ex.preguntas.length;
        $('exam-progress-bar').style.width = '0%';

        var container = $('exam-preguntas');
        container.innerHTML = ex.preguntas.map(function (q, qi) {
          return '<div class="q-block">' +
            '<div class="q-text">' + (qi + 1) + '. ' + escapeHtml(q.texto) + '</div>' +
            q.opciones.map(function (opt, oi) {
              return '<label class="opt-row"><input type="radio" name="exam-resp-' + qi + '" value="' + oi + '"> <span>' + String.fromCharCode(65 + oi) + ') ' + escapeHtml(opt) + '</span></label>';
            }).join('') +
          '</div>';
        }).join('');

        container.querySelectorAll('input[type="radio"]').forEach(function (radio) {
          radio.addEventListener('change', function () { examActualizarProgreso(); });
        });
      }

      function examActualizarProgreso() {
        if (!examEnCurso) return;
        var total = examEnCurso.examen.preguntas.length;
        var respondidas = 0;
        for (var i = 0; i < total; i++) {
          var radios = document.querySelectorAll('input[name="exam-resp-' + i + '"]');
          for (var j = 0; j < radios.length; j++) {
            if (radios[j].checked) { respondidas++; break; }
          }
        }
        $('exam-progress').textContent = respondidas + '/' + total;
        $('exam-progress-bar').style.width = (respondidas / total * 100) + '%';
      }

      function examIniciarTimer() {
        if (examTimerId) clearInterval(examTimerId);
        examTimerId = setInterval(function () {
          if (!examEnCurso) { clearInterval(examTimerId); return; }
          examEnCurso.tiempoRestante--;
          var t = examEnCurso.tiempoRestante;
          var m = Math.floor(t / 60);
          var s = t % 60;
          var timerEl = $('exam-timer');
          timerEl.textContent = String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
          timerEl.className = 'timer';
          if (t <= 60) timerEl.classList.add('danger');
          else if (t <= 180) timerEl.classList.add('warning');
          if (t <= 0) { clearInterval(examTimerId); examEnviar(); }
        }, 1000);
      }

      function examRecolectarRespuestas() {
        if (!examEnCurso) return [];
        return examEnCurso.examen.preguntas.map(function (q, qi) {
          var radios = document.querySelectorAll('input[name="exam-resp-' + qi + '"]');
          var seleccionado = null;
          for (var j = 0; j < radios.length; j++) {
            if (radios[j].checked) { seleccionado = parseInt(radios[j].value, 10); break; }
          }
          return seleccionado;
        });
      }

      function examEnviar() {
        if (!examEnCurso) return;
        clearInterval(examTimerId);
        var respuestas = examRecolectarRespuestas();
        var correctas = 0;
        examEnCurso.examen.preguntas.forEach(function (q, i) {
          if (respuestas[i] !== null && respuestas[i] === q.correcta) correctas++;
        });
        var total = examEnCurso.examen.preguntas.length;
        var porcentaje = total > 0 ? Math.round(correctas / total * 100) : 0;
        var aprobado = porcentaje >= 60;

        $('exam-simulador').classList.add('hidden');
        var resultEl = $('exam-resultado');
        resultEl.className = 'exam-resultado' + (aprobado ? ' aprobado' : ' reprobado');
        resultEl.classList.remove('hidden');
        $('exam-nota').textContent = correctas + '/' + total;
        $('exam-mensaje').textContent = aprobado ? '✅ ¡Aprobado! (' + porcentaje + '%)' : '❌ Reprobado (' + porcentaje + '%). Mínimo 60%';
        examEnCurso = null;
      }

      function examResetSimulador() {
        clearInterval(examTimerId);
        examEnCurso = null;
        $('exam-selector').classList.remove('hidden');
        $('exam-simulador').classList.add('hidden');
        $('exam-resultado').classList.add('hidden');
      }

      // Tab switching
      document.querySelectorAll('[data-exam-tab]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          if (examEnCurso && !confirm('Hay un examen en curso. ¿Salir?')) return;
          examResetSimulador();
          document.querySelectorAll('[data-exam-tab]').forEach(function (b) { b.classList.remove('active'); });
          this.classList.add('active');
          var tab = this.dataset.examTab;
          $('exam-tab-profesor').classList.toggle('hidden', tab !== 'profesor');
          $('exam-tab-estudiante').classList.toggle('hidden', tab !== 'estudiante');
        });
      });

      // Event listeners
      $('btn-exam-add-q').addEventListener('click', examAddPregunta);
      $('btn-exam-guardar').addEventListener('click', examGuardar);
      $('btn-exam-start').addEventListener('click', examComenzar);
      $('btn-exam-enviar').addEventListener('click', function () {
        if (confirm('¿Enviar examen? No podrás cambiar respuestas.')) examEnviar();
      });

      // Init
      examRenderGuardados();
      examCargarSelect();

      /* ===================================================================
         ASISTENCIAS
         =================================================================== */
      var asistEstudiantes = {
        '1A': ['Ana García López','Carlos Mendoza Ruiz','Sofía Ramírez Cruz','Jorge Luis Hernández','Diana Rivas Mora'],
        '1B': ['María Torres Silva','Valentina Ortiz Mora','Pedro Sánchez Vega','Gabriela Flores Ruiz'],
        '2A': ['Luis Fernández Vega','Diego Castillo Pérez','Regina Campos Torres','Fernando Soto Ríos'],
        '2B': ['Ximena Herrera Ríos','Andrés Nava Cruz','Paola Jiménez Díaz'],
        '3A': ['Emiliano Rivas Soto','Alejandra Luna García','Ricardo Paredes Solís'],
        '3B': ['Mateo Delgado Gil','Camila Estrada Ríos','Héctor Medina López'],
      };
      var asistRegistros = [];
      var asistActual = {};

      function setAsistFecha() {
        var hoy = new Date();
        var dd = String(hoy.getDate()).padStart(2,'0');
        var mm = String(hoy.getMonth()+1).padStart(2,'0');
        var yyyy = hoy.getFullYear();
        $('asist-fecha').value = yyyy + '-' + mm + '-' + dd;
      }

      function renderAsistencias() {
        var grupo = $('asist-grupo').value;
        var estudiantes = asistEstudiantes[grupo] || [];
        var container = $('asist-lista');

        if (estudiantes.length === 0) {
          container.innerHTML = '<div class="empty-msg">No hay estudiantes en este grupo.</div>';
          actualizarAsistStats(); return;
        }

        container.innerHTML = estudiantes.map(function (nombre, i) {
          var estado = asistActual[nombre] || 'presente';
          var checkedP = estado === 'presente' ? 'checked' : '';
          var checkedA = estado === 'ausente' ? 'checked' : '';
          var checkedJ = estado === 'justificado' ? 'checked' : '';
          var bg = estado === 'presente' ? '2px solid var(--green)' : estado === 'ausente' ? '2px solid var(--red)' : '2px solid var(--amber)';

          return '<div style="display:grid;grid-template-columns:1fr auto auto;gap:.5rem;align-items:center;padding:.55rem .75rem;border-bottom:1px solid var(--gray-100);border-left:' + bg + ';">' +
            '<span style="font-size:.85rem;font-weight:500;">' + escapeHtml(nombre) + '</span>' +
            '<div style="display:flex;gap:0;background:var(--gray-100);border-radius:8px;overflow:hidden;">' +
              '<label style="padding:.3rem .5rem;font-size:.72rem;cursor:pointer;font-weight:600;transition:.1s;background:' + (estado === 'presente' ? 'var(--green)' : 'transparent') + ';color:' + (estado === 'presente' ? '#fff' : 'var(--gray-500)') + ';">' +
                '<input type="radio" name="asist-' + i + '" value="presente" ' + checkedP + ' style="display:none;"> P' +
              '</label>' +
              '<label style="padding:.3rem .5rem;font-size:.72rem;cursor:pointer;font-weight:600;transition:.1s;background:' + (estado === 'ausente' ? 'var(--red)' : 'transparent') + ';color:' + (estado === 'ausente' ? '#fff' : 'var(--gray-500)') + ';">' +
                '<input type="radio" name="asist-' + i + '" value="ausente" ' + checkedA + ' style="display:none;"> A' +
              '</label>' +
              '<label style="padding:.3rem .5rem;font-size:.72rem;cursor:pointer;font-weight:600;transition:.1s;background:' + (estado === 'justificado' ? 'var(--amber)' : 'transparent') + ';color:' + (estado === 'justificado' ? '#fff' : 'var(--gray-500)') + ';">' +
                '<input type="radio" name="asist-' + i + '" value="justificado" ' + checkedJ + ' style="display:none;"> J' +
              '</label>' +
            '</div></div>';
        }).join('');

        container.querySelectorAll('input[type="radio"]').forEach(function (radio) {
          radio.addEventListener('change', function () {
            if (this.checked) {
              var idx = parseInt(this.name.replace('asist-',''), 10);
              var nombre = estudiantes[idx];
              asistActual[nombre] = this.value;
              renderAsistencias();
            }
          });
        });

        actualizarAsistStats();
      }

      function actualizarAsistStats() {
        var presentes = 0, ausentes = 0, justificados = 0;
        Object.keys(asistActual).forEach(function (nombre) {
          if (asistActual[nombre] === 'presente') presentes++;
          else if (asistActual[nombre] === 'ausente') ausentes++;
          else if (asistActual[nombre] === 'justificado') justificados++;
        });
        $('asist-presentes').textContent = presentes;
        $('asist-ausentes').textContent = ausentes;
        $('asist-justificados').textContent = justificados;
      }

      function renderAsistHistorial() {
        var tbody = $('asist-historial');
        var empty = $('asist-hist-empty');
        if (asistRegistros.length === 0) {
          tbody.innerHTML = ''; empty.style.display = 'block';
          $('asist-hist-total').innerHTML = '<strong>Sin registros</strong>'; return;
        }
        empty.style.display = 'none';
        tbody.innerHTML = asistRegistros.slice().reverse().map(function (r) {
          return '<tr><td>' + r.fecha + '</td><td>' + r.grupo + '</td><td>' + r.presentes + '</td><td>' + r.ausentes + '</td><td>' + r.justificados + '</td><td>' + r.total + '</td></tr>';
        }).join('');
        $('asist-hist-total').innerHTML = '<strong>' + asistRegistros.length + ' registro' + (asistRegistros.length !== 1 ? 's' : '') + '</strong>';
      }

      $('asist-grupo').addEventListener('change', function () {
        asistActual = {};
        renderAsistencias();
      });

      $('asist-fecha').addEventListener('change', function () {
        asistActual = {};
        renderAsistencias();
      });

      $('btn-asist-marcar-todos').addEventListener('click', function () {
        var grupo = $('asist-grupo').value;
        var estudiantes = asistEstudiantes[grupo] || [];
        estudiantes.forEach(function (nombre) { asistActual[nombre] = 'presente'; });
        renderAsistencias();
        mostrarToast('Todos marcados como presentes.', 'success');
      });

      $('btn-asist-guardar').addEventListener('click', function () {
        var grupo = $('asist-grupo').value;
        var fecha = $('asist-fecha').value;
        if (!fecha) { mostrarToast('Selecciona una fecha.', 'error'); return; }
        var estudiantes = asistEstudiantes[grupo] || [];
        if (estudiantes.length === 0) { mostrarToast('No hay estudiantes en este grupo.', 'error'); return; }

        var presentes = 0, ausentes = 0, justificados = 0;
        estudiantes.forEach(function (nombre) {
          var est = asistActual[nombre] || 'presente';
          if (est === 'presente') presentes++;
          else if (est === 'ausente') ausentes++;
          else if (est === 'justificado') justificados++;
        });

        asistRegistros.push({
          fecha: fecha,
          grupo: grupo,
          presentes: presentes,
          ausentes: ausentes,
          justificados: justificados,
          total: estudiantes.length
        });

        renderAsistHistorial();
        mostrarToast('Asistencia del ' + fecha + ' guardada.', 'success');
      });

      setAsistFecha();
      renderAsistencias();
      renderAsistHistorial();

      /* ===================================================================
         TAREAS — Subida de archivos
         =================================================================== */
      var TAR_KEY = 'bachillerato_tareas';
      var tareas = JSON.parse(localStorage.getItem(TAR_KEY) || '[]');
      var tarMaxSize = 5 * 1024 * 1024; // 5MB

      function tarGuardarStorage() { localStorage.setItem(TAR_KEY, JSON.stringify(tareas)); }

      function tarFormatearFecha(d) {
        var date = new Date(d);
        return date.toLocaleDateString('es-MX', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
      }

      function tarFormatearTamaño(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / 1048576).toFixed(1) + ' MB';
      }

      function tarRender() {
        var filtroGrupo = $('tar-filtro-grupo').value;
        var filtroMateria = $('tar-filtro-materia').value;
        var items = tareas.filter(function (t) {
          return (filtroGrupo === 'todos' || t.grupo === filtroGrupo) &&
                 (filtroMateria === 'todos' || t.materia === filtroMateria);
        });
        var el = $('tar-lista');
        if (items.length === 0) {
          el.innerHTML = '<div class="empty-msg">No hay tareas subidas aún.</div>'; return;
        }
        var matNombres = { matematicas: 'Matemáticas', fisica: 'Física', quimica: 'Química', biologia: 'Biología', literatura: 'Literatura', historia: 'Historia', ingles: 'Inglés' };
        el.innerHTML = '<div style="display:flex;flex-direction:column;gap:.5rem;">' +
          items.slice().reverse().map(function (t, i) {
            var realIdx = tareas.indexOf(t);
            return '<div style="display:flex;align-items:center;gap:.75rem;padding:.6rem .75rem;background:var(--gray-50);border-radius:8px;border-left:3px solid var(--primary);">' +
              '<div style="flex:1;min-width:0;">' +
                '<div style="font-weight:600;font-size:.85rem;">' + escapeHtml(t.titulo) + '</div>' +
                '<div style="font-size:.75rem;color:var(--gray-500);display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.15rem;">' +
                  '<span>' + escapeHtml(t.alumno) + '</span>' +
                  '<span class="badge badge-blue">' + (matNombres[t.materia] || t.materia) + '</span>' +
                  '<span class="semestre-badge">' + t.grupo + '</span>' +
                  '<span style="color:var(--gray-400);">' + tarFormatearFecha(t.fecha) + '</span>' +
                  '<span style="color:var(--gray-400);">' + tarFormatearTamaño(t.size) + '</span>' +
                '</div>' +
              '</div>' +
              '<div style="display:flex;gap:.3rem;flex-shrink:0;">' +
                '<button class="btn btn-sm btn-outline tar-descargar" data-idx="' + realIdx + '" style="padding:.2rem .5rem;font-size:.75rem;">&#128229; Ver</button>' +
                '<button class="btn btn-sm tar-eliminar" data-idx="' + realIdx + '" style="background:var(--red);color:#fff;padding:.2rem .5rem;font-size:.75rem;">&#128465;</button>' +
              '</div>' +
            '</div>';
          }).join('') + '</div>';

        el.querySelectorAll('.tar-descargar').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var idx = parseInt(this.dataset.idx);
            var t = tareas[idx];
            if (t && t.dataUrl) {
              var a = document.createElement('a');
              a.href = t.dataUrl;
              a.download = t.fileName;
              document.body.appendChild(a);
              a.click();
              document.body.removeChild(a);
            }
          });
        });
        el.querySelectorAll('.tar-eliminar').forEach(function (btn) {
          btn.addEventListener('click', function () {
            if (!confirm('¿Eliminar esta tarea?')) return;
            var idx = parseInt(this.dataset.idx);
            tareas.splice(idx, 1);
            tarGuardarStorage();
            tarRender();
            mostrarToast('Tarea eliminada.', 'success');
          });
        });
      }

      $('btn-tar-subir').addEventListener('click', function () {
        var titulo = $('tar-titulo').value.trim();
        var grupo = $('tar-grupo').value;
        var materia = $('tar-materia').value;
        var fileInput = $('tar-file');
        var msgEl = $('tar-msg');

        if (!logueado) { mostrarToast('Inicia sesión para subir tareas.', 'error'); return; }
        if (!titulo) { msgEl.textContent = '⚠️ Escribe un título.'; msgEl.style.color = 'var(--red)'; return; }
        if (!fileInput.files || fileInput.files.length === 0) { msgEl.textContent = '⚠️ Selecciona un archivo.'; msgEl.style.color = 'var(--red)'; return; }

        var file = fileInput.files[0];
        if (file.size > tarMaxSize) { msgEl.textContent = '⚠️ El archivo excede 5 MB.'; msgEl.style.color = 'var(--red)'; return; }

        var reader = new FileReader();
        reader.onload = function (e) {
          tareas.push({
            titulo: titulo,
            grupo: grupo,
            materia: materia,
            alumno: $('user-email-display').textContent || 'Anónimo',
            fileName: file.name,
            fileType: file.type || 'application/octet-stream',
            size: file.size,
            dataUrl: e.target.result,
            fecha: new Date().toISOString()
          });
          tarGuardarStorage();
          tarRender();
          $('tar-titulo').value = '';
          $('tar-file').value = '';
          msgEl.textContent = '✔️ Tarea "' + titulo + '" subida correctamente.';
          msgEl.style.color = 'var(--green)';
          mostrarToast('Tarea subida: ' + titulo, 'success');
        };
        reader.onerror = function () {
          msgEl.textContent = '⚠️ Error al leer el archivo.';
          msgEl.style.color = 'var(--red)';
        };
        reader.readAsDataURL(file);
      });

      $('btn-tar-refresh').addEventListener('click', function () { tarRender(); mostrarToast('Lista actualizada.', 'success'); });
      $('tar-filtro-grupo').addEventListener('change', tarRender);
      $('tar-filtro-materia').addEventListener('change', tarRender);

      tarRender();

      /* ===================================================================
         SABI — Analítica del Bachillerato
         =================================================================== */
      var recomendaciones = [
        { texto: 'Ana García (1°A) — riesgo en matemáticas. Reforzar álgebra.', tipo: 'academico' },
        { texto: 'Carlos Mendoza (1°A) — mejoró 18% en lectura. Mantener método.', tipo: 'logro' },
        { texto: 'Grupo 2°A — bajo rendimiento en física. Actividad práctica recomendada.', tipo: 'grupo' },
        { texto: 'María Torres (1°B) — 4 inasistencias consecutivas. Notificar a padres.', tipo: 'alerta' },
        { texto: 'Luis Fernández (2°A) — destaca en artes. Recomendar taller de literatura.', tipo: 'recomendacion' },
        { texto: '3° Semestre — preparación para PAES. Programa intensivo sugerido.', tipo: 'grupo' },
        { texto: 'Valentina Ortiz (1°B) — riesgo en química. Tutoría sugerida.', tipo: 'academico' },
        { texto: 'Diego Castillo (3°A) — mejor rendimiento del semestre. Felicitar.', tipo: 'logro' },
      ];

      function renderSabi() {
        var el = $('sabi-recomendaciones-list');
        el.innerHTML = recomendaciones.map(function (r) {
          var icono = { academico: '📚', logro: '🏆', grupo: '👥', alerta: '⚠️', recomendacion: '💡' }[r.tipo] || '📌';
          return '<div style="display:flex;gap:.75rem;padding:.6rem 0;border-bottom:1px solid var(--gray-200);align-items:flex-start;font-size:.85rem;">' +
            '<span style="font-size:1.1rem;">' + icono + '</span>' +
            '<span>' + escapeHtml(r.texto) + '</span></div>';
        }).join('');
      }
      renderSabi();

      /* ===================================================================
         INICIO
         =================================================================== */
      mostrarApp('inicio');

    })();
  </script>

  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('sw.js').then(function (reg) {
        console.log('SW registrado, alcance:', reg.scope);
      }).catch(function (err) {
        console.log('Error al registrar SW:', err);
      });
    }
  </script>
</body>
</html>
