<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="EduGest — Ecosistema integral para bachilleratos: gestión académica, picker, recursos digitales, analítica y más.">
  <meta name="theme-color" content="#2563eb">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="EduGest">
  <meta name="mobile-web-app-capable" content="yes">
  <link rel="manifest" href="manifest.json">
  <link rel="icon" href="icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="icon.svg">
  <title>EduGest · Bachillerato</title>
  <style>
    :root {
      --primary: #2563eb; --primary-dark: #1d4ed8; --primary-light: #dbebff;
      --gray-50: #f9fafb; --gray-100: #f3f4f6; --gray-200: #e5e7eb;
      --gray-300: #d1d5db; --gray-500: #6b7280; --gray-700: #374151; --gray-900: #111827;
      --radius: 12px; --green: #16a34a; --green-light: #dcfce7;
      --red: #dc2626; --red-light: #fef2f2; --amber: #d97706; --amber-light: #fef3c7;
      --purple: #7c3aed; --purple-light: #ede9fe; --teal: #0d9488; --teal-light: #ccfbf1;
      --pink: #db2777; --pink-light: #fce7f3; --orange: #ea580c; --orange-light: #ffedd5;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      color: var(--gray-900); background: #fff; line-height: 1.6;
    }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 1rem; }
    @media (min-width: 768px) { .container { padding: 0 1.5rem; } }
    .hidden { display: none !important; }

    /* ===== HEADER ===== */
    .app-header { background: #fff; border-bottom: 1px solid var(--gray-200); padding: .6rem 0; position: sticky; top: 0; z-index: 100; }
    .app-header .container { display: flex; align-items: center; gap: .5rem; }
    .logo-link { display: flex; align-items: center; gap: .5rem; text-decoration: none; color: var(--gray-900); font-weight: 800; font-size: 1.1rem; flex-shrink: 0; }
    .logo-link svg { width: 28px; height: 28px; flex-shrink: 0; }
    .main-nav { overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; flex: 1; }
    .main-nav::-webkit-scrollbar { display: none; }
    .main-nav ul { display: flex; gap: .15rem; list-style: none; white-space: nowrap; padding: .15rem 0; }
    .main-nav a { padding: .4rem .6rem; border-radius: 8px; text-decoration: none; color: var(--gray-600); font-weight: 500; font-size: .78rem; transition: .2s; cursor: pointer; display: inline-block; }
    .main-nav a:hover, .main-nav a.active { background: var(--primary-light); color: var(--primary); }

    /* ===== BUTTONS ===== */
    .btn { display: inline-flex; align-items: center; justify-content: center; gap: .35rem; padding: .55rem 1rem; border: none; border-radius: 10px; font: inherit; font-weight: 600; font-size: .85rem; cursor: pointer; transition: .2s; text-decoration: none; min-height: 40px; }
    .btn:active { transform: scale(.97); }
    .btn-primary { background: var(--primary); color: #fff; box-shadow: 0 2px 8px rgba(37,99,235,.25); }
    .btn-outline { background: transparent; color: var(--primary); border: 1.5px solid var(--primary); }
    .btn-sm { padding: .35rem .7rem; font-size: .78rem; min-height: 32px; }
    .btn-block { width: 100%; }

    /* ===== SECTIONS ===== */
    .section { padding: 2rem 0; }
    .section-title { text-align: center; font-size: 1.3rem; margin-bottom: .3rem; padding: 0 1rem; }
    .section-sub { text-align: center; color: var(--gray-500); margin-bottom: 1.5rem; font-size: .88rem; padding: 0 1rem; }
    .bg-gray { background: var(--gray-50); }

    /* ===== APP GRID ===== */
    .app-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: .75rem; }
    @media (min-width: 480px) { .app-grid { grid-template-columns: repeat(3, 1fr); } }
    .app-card { background: #fff; border: 1px solid var(--gray-200); border-radius: var(--radius); padding: 1rem .75rem; text-align: center; cursor: pointer; transition: .15s; }
    .app-card:active { background: var(--gray-50); }
    .app-card .icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin: 0 auto .4rem; font-weight: 800; font-size: 1rem; }
    .app-card h4 { font-size: .82rem; margin-bottom: .15rem; }
    .app-card p { font-size: .7rem; color: var(--gray-500); }

    /* ===== FORMS ===== */
    .form-group { margin-bottom: .75rem; }
    .form-group label { display: block; font-weight: 600; margin-bottom: .25rem; font-size: .82rem; }
    .form-group input, .form-group select, .form-group textarea { width: 100%; padding: .65rem .75rem; border: 1px solid var(--gray-300); border-radius: 10px; font: inherit; font-size: .9rem; transition: .2s; -webkit-appearance: none; appearance: none; }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px var(--primary-light); }
    .form-row { display: flex; gap: .75rem; flex-wrap: wrap; }
    .form-row .form-group { flex: 1; min-width: 140px; }

    /* ===== TABLE ===== */
    .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; margin: 0 -.5rem; padding: 0 .5rem; }
    table { width: 100%; border-collapse: collapse; font-size: .78rem; min-width: 500px; }
    th, td { text-align: left; padding: .55rem .4rem; border-bottom: 1px solid var(--gray-200); }
    th { background: var(--gray-100); font-weight: 600; white-space: nowrap; }
    tfoot td { background: var(--gray-50); font-weight: 600; border-top: 2px solid var(--gray-300); }

    /* ===== BADGES ===== */
    .badge { display: inline-block; font-size: .65rem; font-weight: 600; padding: .12rem .45rem; border-radius: 99px; white-space: nowrap; }
    .badge-blue { background: var(--primary-light); color: var(--primary); }
    .badge-green { background: var(--green-light); color: var(--green); }
    .badge-amber { background: var(--amber-light); color: var(--amber); }
    .badge-red { background: var(--red-light); color: var(--red); }
    .badge-purple { background: var(--purple-light); color: var(--purple); }
    .badge-orange { background: var(--orange-light); color: var(--orange); }
    .badge-teal { background: var(--teal-light); color: var(--teal); }
    .badge-pink { background: var(--pink-light); color: var(--pink); }

    /* ===== CARD ===== */
    .card { background: #fff; border: 1px solid var(--gray-200); border-radius: var(--radius); padding: 1.25rem; }
    .card h3 { font-size: .95rem; margin-bottom: .85rem; display: flex; align-items: center; gap: .5rem; }

    /* ===== TOAST ===== */
    .toast { position: fixed; bottom: 1.5rem; left: 1rem; right: 1rem; padding: .85rem 1.25rem; border-radius: var(--radius); color: #fff; font-weight: 600; font-size: .88rem; text-align: center; transform: translateY(calc(100% + 2rem)); opacity: 0; transition: .35s; z-index: 300; box-shadow: 0 8px 24px rgba(0,0,0,.15); }
    .toast.show { transform: translateY(0); opacity: 1; }
    .toast-success { background: var(--green); }
    .toast-error { background: var(--red); }

    /* ===== LAYOUT ===== */
    .flex-between { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: .6rem; }
    .grid-2 { display: grid; grid-template-columns: 1fr; gap: 1rem; }
    @media (min-width: 600px) { .grid-2 { grid-template-columns: 1fr 1fr; } }
    .grid-3 { display: grid; grid-template-columns: repeat(2, 1fr); gap: .75rem; }
    @media (min-width: 480px) { .grid-3 { grid-template-columns: repeat(3, 1fr); } }
    .grid-4 { display: grid; grid-template-columns: repeat(2, 1fr); gap: .6rem; }

    /* ===== STATS ===== */
    .stat-box { text-align: center; padding: .85rem .5rem; background: var(--gray-50); border-radius: 10px; }
    .stat-num { font-size: 1.5rem; font-weight: 800; color: var(--primary); }
    .stat-label { font-size: .72rem; color: var(--gray-500); }

    /* ===== EMPTY ===== */
    .empty-msg { text-align: center; padding: 1.5rem; color: var(--gray-500); font-style: italic; font-size: .85rem; }

    /* ===== PICKER ===== */
    .picker-stage { max-width: 100%; margin: 0 auto; text-align: center; }
    .picker-display { width: 160px; height: 160px; border-radius: 50%; background: var(--primary); color: #fff; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; font-size: 1.4rem; font-weight: 800; padding: .5rem; text-align: center; word-break: break-word; transition: .15s; box-shadow: 0 8px 24px rgba(37,99,235,.25); }
    @media (min-width: 480px) { .picker-display { width: 200px; height: 200px; font-size: 1.7rem; } }
    .picker-spinning { animation: pulse .4s infinite alternate; }
    @keyframes pulse { from { transform: scale(1); } to { transform: scale(1.06); } }

    .progress-bar { height: 6px; background: var(--gray-200); border-radius: 99px; overflow: hidden; margin: .4rem 0; }
    .progress-fill { height: 100%; background: var(--primary); border-radius: 99px; transition: width .4s; }

    /* ===== TABS ===== */
    .tab-bar { display: flex; gap: 0; background: var(--gray-100); border-radius: 10px; overflow: hidden; margin-bottom: 1rem; }
    .tab-bar button { flex: 1; padding: .5rem .4rem; border: none; background: transparent; font-weight: 600; font-size: .78rem; cursor: pointer; transition: .2s; color: var(--gray-500); white-space: nowrap; }
    .tab-bar button.active { background: #fff; color: var(--primary); box-shadow: 0 1px 4px rgba(0,0,0,.06); border-radius: 8px; margin: 2px; }

    /* ===== EXAM VIEWS ===== */
    .exam-creator .pregunta-item { background: var(--gray-50); border-radius: 10px; padding: 1rem; margin-bottom: .75rem; border-left: 3px solid var(--primary); }
    .exam-creator .pregunta-item .opt-row { display: flex; align-items: center; gap: .5rem; margin-top: .35rem; }
    .exam-creator .pregunta-item .opt-row input[type="text"] { flex: 1; padding: .4rem .6rem; border: 1px solid var(--gray-300); border-radius: 6px; font-size: .85rem; }
    .exam-creator .pregunta-item .opt-row input[type="radio"] { width: 18px; height: 18px; cursor: pointer; flex-shrink: 0; }
    .exam-creator .pregunta-item .opt-label { font-size: .8rem; font-weight: 600; color: var(--gray-500); min-width: 20px; }
    .pregunta-textarea { width: 100%; padding: .5rem .7rem; border: 1px solid var(--gray-300); border-radius: 8px; font: inherit; font-size: .88rem; resize: vertical; min-height: 50px; margin-bottom: .4rem; }

    .exam-student .exam-info { text-align: center; padding: 1.5rem; }
    .exam-student .timer { font-size: 2.5rem; font-weight: 800; color: var(--primary); font-variant-numeric: tabular-nums; }
    .exam-student .timer.warning { color: var(--amber); }
    .exam-student .timer.danger { color: var(--red); animation: pulse .6s infinite alternate; }
    .exam-student .q-block { background: var(--gray-50); border-radius: 10px; padding: 1rem; margin-bottom: .75rem; }
    .exam-student .q-block .q-text { font-weight: 600; margin-bottom: .5rem; font-size: .95rem; }
    .exam-student .q-block .opt-row { display: flex; align-items: center; gap: .6rem; padding: .4rem; border-radius: 8px; cursor: pointer; transition: .1s; }
    .exam-student .q-block .opt-row:hover { background: var(--gray-100); }
    .exam-student .q-block .opt-row input[type="radio"] { width: 18px; height: 18px; cursor: pointer; }
    .exam-resultado { text-align: center; padding: 2rem; border-radius: var(--radius); }
    .exam-resultado.aprobado { background: var(--green-light); color: var(--green); }
    .exam-resultado.reprobado { background: var(--red-light); color: var(--red); }
    .exam-resultado .nota { font-size: 3rem; font-weight: 800; }
    .exam-resultado .mensaje { font-size: 1.1rem; font-weight: 600; margin-top: .5rem; }

    /* ===== SEMESTRE ===== */
    .semestre-badge { display: inline-block; font-size: .65rem; font-weight: 600; padding: .12rem .4rem; border-radius: 4px; background: var(--gray-100); color: var(--gray-700); white-space: nowrap; }

    /* ===== MODAL ===== */
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 200; justify-content: center; align-items: flex-end; padding: 1rem; }
    @media (min-width: 500px) { .modal-overlay { align-items: center; } }
    .modal-overlay.open { display: flex; }
    .modal { background: #fff; border-radius: var(--radius) var(--radius) 0 0; padding: 1.5rem; max-width: 400px; width: 100%; box-shadow: 0 -8px 24px rgba(0,0,0,.1); max-height: 90vh; overflow-y: auto; }
    @media (min-width: 500px) { .modal { border-radius: var(--radius); } }
    .modal-close { background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--gray-500); padding: .25rem; line-height: 1; }

    /* ===== HERO ===== */
    .hero-section { background: linear-gradient(135deg,#1e3a5f,#2563eb,#1d4ed8); color: #fff; padding: 3rem 1rem 2.5rem; text-align: center; }
    .hero-section h1 { font-size: 1.6rem; line-height: 1.25; margin-bottom: .6rem; }
    .hero-section p { font-size: .9rem; opacity: .9; max-width: 500px; margin: 0 auto 1.25rem; }

    /* ===== FOOTER ===== */
    .app-footer { background: var(--gray-900); color: var(--gray-400); padding: 1.5rem 0; text-align: center; font-size: .78rem; }
    .app-footer a { color: var(--gray-400); }

    /* ===== UTILITIES ===== */
    .mt-0 { margin-top: 0; }
    .mb-0 { margin-bottom: 0; }
    .gap-0 { gap: 0; }
    .w-full { width: 100%; }

    @media (max-width: 480px) {
      .hide-mobile { display: none !important; }
      .section-title { font-size: 1.15rem; }
      .app-header { padding: .4rem 0; }
      .logo-link { font-size: .95rem; gap: .35rem; }
      .logo-link svg { width: 24px; height: 24px; }
      .main-nav a { font-size: .72rem; padding: .3rem .5rem; }
      .btn { font-size: .8rem; padding: .5rem .85rem; min-height: 36px; }
      .card { padding: 1rem; }
      .grid-3 { grid-template-columns: repeat(2, 1fr); gap: .6rem; }
      .stat-num { font-size: 1.3rem; }
      .picker-display { width: 130px; height: 130px; font-size: 1.1rem; }
      input, select, textarea { font-size: 16px !important; }
    }

    @media (min-width: 481px) and (max-width: 768px) {
      .hero-section { padding: 3.5rem 1.5rem 3rem; }
      .hero-section h1 { font-size: 2rem; }
    }
  </style>
</head>
<body>

  <!-- ========== HEADER ========== -->
  <header class="app-header">
    <div class="container">
      <a href="#" class="logo-link" onclick="mostrarApp(null)">
        <svg width="32" height="32" viewBox="0 0 32 32"><rect width="32" height="32" rx="7" fill="#2563eb"/><text x="16" y="22" text-anchor="middle" font-family="system-ui" font-size="18" font-weight="bold" fill="white">B</text></svg>
        <span>EduGest · Bachillerato</span>
      </a>
      <nav class="main-nav" aria-label="Navegación principal">
        <ul>
          <li><a data-app="inicio" class="active">Inicio</a></li>
          <li><a data-app="picker">Picker</a></li>
          <li><a data-app="digital">Digital</a></li>
          <li><a data-app="parents">Parents</a></li>
          <li><a data-app="auth">Auth</a></li>
          <li><a data-app="experiencias">Experiencias</a></li>
          <li><a data-app="examenes">Exámenes</a></li>
          <li><a data-app="tareas">Tareas</a></li>
          <li><a data-app="asistencias">Asistencias</a></li>
          <li><a data-app="sabi">SABI</a></li>
        </ul>
      </nav>
      <div style="display:flex;gap:.5rem;align-items:center;">
        <button class="btn btn-outline btn-sm" id="btn-login">Ingresar</button>
        <div id="user-info" class="hidden" style="display:none;align-items:center;gap:.5rem;">
          <span id="user-email-display" style="color:var(--gray-700);font-weight:500;font-size:.82rem;"></span>
          <button class="btn btn-sm" id="btn-logout" style="background:var(--gray-100);color:var(--gray-700);">Salir</button>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== LOGIN MODAL ========== -->
  <div class="modal-overlay" id="modal-login">
    <div class="modal">
      <div class="flex-between"><h3>Iniciar sesión</h3><button class="modal-close" id="modal-login-close">&times;</button></div>
      <form id="form-login">
        <div class="form-group"><label>Correo institucional</label><input type="email" id="login-email" placeholder="profesor@bachillerato.edu" required></div>
        <div class="form-group"><label>Contraseña</label><input type="password" id="login-pass" placeholder="••••••" required minlength="6"></div>
        <button type="submit" class="btn btn-primary btn-block">Ingresar</button>
        <div id="login-error" class="alert alert-error" role="alert" hidden style="margin-top:.75rem;background:var(--red-light);color:#991b1b;border:1px solid #fecaca;padding:.65rem 1rem;border-radius:8px;font-size:.85rem;">Credenciales inválidas.</div>
      </form>
      <p style="margin-top:.75rem;font-size:.8rem;text-align:center;color:var(--gray-500);"><a href="#" id="link-olvide">Olvidé mi contraseña</a></p>
    </div>
  </div>

  <div class="toast" id="toast" role="alert" aria-live="polite"></div>

  <!-- ========== MAIN ========== -->
  <main>

    <!-- ===== INICIO ===== -->
    <section id="app-inicio">
      <div class="hero-section">
        <div class="container">
          <p style="font-size:.8rem;text-transform:uppercase;letter-spacing:2px;opacity:.7;margin-bottom:.5rem;">Ecosistema Integral para Bachilleratos</p>
          <h1 style="font-size:clamp(1.8rem,4vw,2.8rem);line-height:1.2;margin-bottom:.75rem;">Tu bachillerato, más inteligente</h1>
          <p style="font-size:1rem;opacity:.9;max-width:600px;margin:0 auto 1.5rem;">6 aplicaciones diseñadas para estudiantes, docentes, coordinadores y padres de familia en educación media superior.</p>
          <div style="display:flex;gap:.75rem;justify-content:center;flex-wrap:wrap;">
            <button class="btn" style="background:#fff;color:var(--primary);" onclick="document.getElementById('btn-login').click()">Ingresar ahora</button>
          </div>
        </div>
      </div>

      <section class="section" style="padding:2.5rem 0;">
        <div class="container">
          <div class="app-grid" style="grid-template-columns:repeat(auto-fill,minmax(160px,1fr));">
            <div class="app-card" onclick="mostrarApp('picker')"><div class="icon" style="background:var(--purple-light);color:var(--purple);">P</div><h4>Picker</h4><p>Participación en el aula</p></div>
            <div class="app-card" onclick="mostrarApp('digital')"><div class="icon" style="background:var(--green-light);color:var(--green);">D</div><h4>Digital</h4><p>Recursos de bachillerato</p></div>
            <div class="app-card" onclick="mostrarApp('parents')"><div class="icon" style="background:var(--amber-light);color:var(--amber);">P</div><h4>Parents</h4><p>Seguimiento académico</p></div>
            <div class="app-card" onclick="mostrarApp('auth')"><div class="icon" style="background:var(--primary-light);color:var(--primary);">A</div><h4>Auth</h4><p>Usuarios y roles</p></div>
            <div class="app-card" onclick="mostrarApp('experiencias')"><div class="icon" style="background:var(--pink-light);color:var(--pink);">E</div><h4>Experiencias</h4><p>Rutas de aprendizaje</p></div>
            <div class="app-card" onclick="mostrarApp('examenes')"><div class="icon" style="background:var(--purple-light);color:var(--purple);">E</div><h4>Exámenes</h4><p>Creador y simulador</p></div>
            <div class="app-card" onclick="mostrarApp('asistencias')"><div class="icon" style="background:var(--orange-light);color:var(--orange);">A</div><h4>Asistencias</h4><p>Control de asistencia</p></div>
            <div class="app-card" onclick="mostrarApp('tareas')"><div class="icon" style="background:var(--pink-light);color:var(--pink);">T</div><h4>Tareas</h4><p>Sube tus trabajos</p></div>
            <div class="app-card" onclick="mostrarApp('sabi')"><div class="icon" style="background:var(--teal-light);color:var(--teal);">S</div><h4>SABI</h4><p>Analítica educativa</p></div>
          </div>
        </div>
      </section>
    </section>

    <!-- ===== PICKER ===== -->
    <section id="app-picker" class="section hidden">
      <div class="container">
        <h2 class="section-title">&#127922; Picker · Participación en Bachillerato</h2>
        <p class="section-sub">Selecciona estudiantes al azar para promover la participación equitativa en clase.</p>
        <div class="grid-2">
          <div class="card picker-stage">
            <div class="picker-display" id="picker-display">—</div>
            <div class="flex-between" style="margin-bottom:.75rem;">
              <select id="picker-grupo" style="padding:.5rem;border:1px solid var(--gray-300);border-radius:8px;font:inherit;flex:1;margin-right:.5rem;">
                <option value="todos">Todos los grupos</option>
                <option value="1A">1° Semestre A</option>
                <option value="1B">1° Semestre B</option>
                <option value="2A">2° Semestre A</option>
                <option value="2B">2° Semestre B</option>
                <option value="3A">3° Semestre A</option>
                <option value="3B">3° Semestre B</option>
              </select>
              <button class="btn btn-primary" id="btn-picker-spin">&#9654; Girar</button>
            </div>
            <div class="progress-bar"><div class="progress-fill" id="picker-progress" style="width:0%"></div></div>
            <p style="font-size:.82rem;color:var(--gray-500);margin-top:.5rem;">&#128337; Últimos seleccionados:</p>
            <div id="picker-history" style="display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.3rem;"></div>
          </div>
