      function examGetPreguntas() {
        var items = document.querySelectorAll('#exam-q-list .pregunta-item');
        var preguntas = [];
        items.forEach(function (item) {
          var idx = item.querySelector('.pregunta-textarea').dataset.idx;
          var texto = item.querySelector('.pregunta-textarea').value.trim();
          var optA = item.querySelector('input[data-opt="0"]').value.trim();
          var optB = item.querySelector('input[data-opt="1"]').value.trim();
          var optC = item.querySelector('input[data-opt="2"]').value.trim();
          var correcta = item.querySelector('input[name="correcta-' + idx + '"]:checked');
          if (!texto) return; // skip empty
          preguntas.push({
            texto: texto,
            opciones: [optA || '—', optB || '—', optC || '—'],
            correcta: correcta ? parseInt(correcta.value, 10) : 0
          });
        });
        return preguntas;
      }

      function examGuardar() {
        var titulo = $('exam-titulo').value.trim();
        var tiempo = parseInt($('exam-tiempo').value, 10) || 60;
        if (!titulo) { $('exam-guardar-msg').textContent = '⚠️ El título es obligatorio.'; $('exam-guardar-msg').style.color = 'var(--red)'; return; }
        var preguntas = examGetPreguntas();
        if (preguntas.length === 0) { $('exam-guardar-msg').textContent = '⚠️ Agrega al menos 1 pregunta.'; $('exam-guardar-msg').style.color = 'var(--red)'; return; }
        examenes.push({ titulo: titulo, tiempo: tiempo, preguntas: preguntas });
        examGuardarStorage();
        examRenderGuardados();
        examCargarSelect();
        $('exam-titulo').value = '';
        $('exam-tiempo').value = '60';
        $('exam-q-list').innerHTML = '';
        examQCount = 0;
        $('exam-guardar-msg').textContent = '✔️ Examen guardado correctamente.';
        $('exam-guardar-msg').style.color = 'var(--green)';
        setTimeout(function () { $('exam-guardar-msg').textContent = ''; }, 3000);
      }

      function examCargarSelect() {
        var sel = $('exam-select');
        sel.innerHTML = '';
        if (examenes.length === 0) {
          sel.innerHTML = '<option value="">— Sin exámenes disponibles —</option>'; return;
        }
        examenes.forEach(function (e, i) {
          var opt = document.createElement('option');
          opt.value = i;
          opt.textContent = e.titulo + ' (' + e.preguntas.length + ' preg, ' + e.tiempo + ' min)';
          sel.appendChild(opt);
