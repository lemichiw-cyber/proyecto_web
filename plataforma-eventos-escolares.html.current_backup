  <script>
    (function () {
      'use strict';

      var logueado = false;
      var apps = ['inicio','picker','digital','parents','auth','experiencias','examenes','tareas','asistencias','sabi'];
      var appsProtegidas = ['picker','digital','parents','auth','experiencias','examenes','tareas','asistencias','sabi'];

      function $(id) { return document.getElementById(id); }

      var toastEl = $('toast');
      var toastTimeout;
      function mostrarToast(msg, tipo) {
        clearTimeout(toastTimeout);
        toastEl.textContent = msg;
        toastEl.className = 'toast toast-' + tipo + ' show';
        toastTimeout = setTimeout(function () { toastEl.classList.remove('show'); }, 3500);
      }

      window.mostrarApp = function (app) {
        if (app && appsProtegidas.indexOf(app) !== -1 && !logueado) {
          $('modal-login').classList.add('open');
          mostrarToast('Inicia sesión para acceder.', 'error');
          return;
        }
        apps.forEach(function (a) {
          var el = $('app-' + a);
          if (el) el.classList.toggle('hidden', a !== (app || 'inicio'));
        });
        document.querySelectorAll('[data-app]').forEach(function (link) {
          link.classList.toggle('active', link.dataset.app === (app || 'inicio'));
        });
        window.scrollTo({ top: 0, behavior: 'smooth' });
      };

      document.querySelectorAll('[data-app]').forEach(function (link) {
        link.addEventListener('click', function (e) { e.preventDefault(); mostrarApp(this.dataset.app); });
      });

      /* ===== LOGIN ===== */
      var modalLogin = $('modal-login');
      $('btn-login').addEventListener('click', function () { modalLogin.classList.add('open'); });
      $('modal-login-close').addEventListener('click', function () { modalLogin.classList.remove('open'); });
      modalLogin.addEventListener('click', function (e) { if (e.target === modalLogin) modalLogin.classList.remove('open'); });

      $('form-login').addEventListener('submit', function (e) {
        e.preventDefault();
        var email = $('login-email').value.trim();
        var pass = $('login-pass').value.trim();
        if (!email || pass.length < 6) {
          $('login-error').hidden = false; mostrarToast('Correo o contraseña inválidos.', 'error'); return;
        }
        $('login-error').hidden = true;
        logueado = true;
        modalLogin.classList.remove('open');
        $('btn-login').style.display = 'none';
        var ui = $('user-info');
        ui.style.display = 'flex'; ui.classList.remove('hidden');
        $('user-email-display').textContent = email;
        mostrarToast('Bienvenido, ' + email, 'success');
        $('form-login').reset();
      });

      $('btn-logout').addEventListener('click', function () {
        logueado = false;
        $('btn-login').style.display = '';
        var ui = $('user-info'); ui.style.display = 'none'; ui.classList.add('hidden');
        mostrarApp('inicio');
        mostrarToast('Sesión cerrada.', 'success');
      });

      $('link-olvide').addEventListener('click', function (e) {
        e.preventDefault(); modalLogin.classList.remove('open');
        mostrarToast('Te enviamos un enlace de recuperación al correo.', 'success');
      });

      function escapeHtml(s) { if (typeof s !== 'string') return s; var d = document.createElement('div'); d.appendChild(document.createTextNode(s)); return d.innerHTML; }

      /* ===================================================================
         PICKER — Bachillerato
         =================================================================== */
      var pickerStudents = [
        { nombre: 'Ana García López', grupo: '1A' },
        { nombre: 'Carlos Mendoza Ruiz', grupo: '1A' },
        { nombre: 'María Torres Silva', grupo: '1B' },
        { nombre: 'Luis Fernández Vega', grupo: '2A' },
        { nombre: 'Sofía Ramírez Cruz', grupo: '2A' },
        { nombre: 'Diego Castillo Pérez', grupo: '3A' },
        { nombre: 'Valentina Ortiz Mora', grupo: '1B' },
        { nombre: 'Emiliano Rivas Soto', grupo: '3A' },
        { nombre: 'Ximena Herrera Ríos', grupo: '2B' },
        { nombre: 'Mateo Delgado Gil', grupo: '3B' },
      ];

      var pickerHistory = [];

      function renderPickerList() {
        var g = $('picker-grupo').value;
        var filtrados = g === 'todos' ? pickerStudents : pickerStudents.filter(function (s) { return s.grupo === g; });
        var el = $('picker-list');
        if (filtrados.length === 0) { el.innerHTML = '<div class="empty-msg">No hay estudiantes en este grupo.</div>'; return; }
        el.innerHTML = '<div style="display:flex;flex-direction:column;gap:.4rem;">' + filtrados.map(function (s, i) {
          return '<div style="display:flex;justify-content:space-between;align-items:center;padding:.4rem .6rem;background:var(--gray-50);border-radius:6px;">' +
            '<span>' + escapeHtml(s.nombre) + ' <span class="semestre-badge">' + s.grupo + '</span></span>' +
            '<button class="btn btn-sm picker-del" data-idx="' + pickerStudents.indexOf(s) + '" style="background:var(--red);color:#fff;padding:.15rem .4rem;font-size:.7rem;">×</button></div>';
        }).join('') + '</div>';
        el.querySelectorAll('.picker-del').forEach(function (btn) {
          btn.addEventListener('click', function () {
            pickerStudents.splice(parseInt(this.dataset.idx), 1);
            renderPickerList();
            mostrarToast('Estudiante eliminado.', 'success');
          });
        });
      }

